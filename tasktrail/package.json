{
  "name": "tasktrail",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "apply-migration": "concurrently --kill-others \"npx prisma generate\" \"npx prisma migrate deploy\"",
    "deploy": "sass --no-source-map public/sass/:public/css/ && npm run build:prod",
    "css-build": "sass --no-source-map public/sass/:public/css/",
    "css-watch": "npm run css-build -- --watch",
    "dev": "concurrently --kill-others-on-fail --names server,sass,client \"node --watch ./bin/www\" \"npm run css-watch\" \"webpack serve --mode=development\"",
    "start": "node ./bin/www",
    "start:prod": "node ./bin/www",
    "build": "webpack --mode=production",
    "build:dev": "npm run dev",
    "build:prod": "concurrently --kill-others \"npm run start:prod\" \"webpack serve --mode=production\""
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.6",
    "@fullcalendar/daygrid": "^6.1.6",
    "@fullcalendar/interaction": "^6.1.6",
    "@fullcalendar/list": "^6.1.8",
    "@fullcalendar/vue3": "^6.1.20",
    "@prisma/client": "^4.15.0",
    "@thesameeric/fileguard": "^1.1.2",
    "@types/alertify": "^0.3.31",
    "alertifyjs": "^1.13.1",
    "bcrypt": "^6.0.0",
    "bulma": "^0.9.4",
    "concurrently": "^7.6.0",
    "core-js": "^3.46.0",
    "cookie-parser": "~1.4.4",
    "cookie-session": "^2.0.0",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-handlebars": "^7.0.7",
    "http-errors": "~1.6.3",
    "i18n": "^0.15.1",
    "jsonwebtoken": "^9.0.0",
    "mariadb": "^3.1.0",
    "mime": "^3.0.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "nodemailer-express-handlebars": "^6.1.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^4.15.0",
    "pug": "^3.0.2",
    "pug-plain-loader": "^1.1.0",
    "v-calendar": "^3.1.2",
    "validator": "^13.9.0",
    "vue": "^3.5.35",
    "vue-color": "^3.3.3",
    "vue-i18n": "^11.4.5",
    "vue-loader": "^17.4.2",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@vue/language-plugin-pug": "^3.1.5",
    "css-loader": "^6.7.3",
    "sass": "^1.89.2",
    "sass-loader": "^13.2.0",
    "style-loader": "^3.3.2",
    "webpack": "^5.76.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.4"
  },
  "overrides": {
    "postcss": "8.5.15",
    "uuid": "11.1.1"
  }
}
