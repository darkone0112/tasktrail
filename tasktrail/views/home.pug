doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(http-equiv="X-UA-Compatible" content="IE=edge")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title= title
        style.
            html, body { background-color: #ffffff; }
            html.dark-theme, html.dark-theme body { background-color: #0f0f0f; }
            html.high-contrast-theme, html.high-contrast-theme body { background-color: #000000; }
        script.
            (() => {
                try {
                    const savedTheme = JSON.parse(localStorage.getItem("theme") || "null");
                    const theme = Array.isArray(savedTheme) ? savedTheme[0] : savedTheme;
                    if (theme && ["dark-theme", "high-contrast-theme"].includes(theme.styleName)) {
                        document.documentElement.classList.add(theme.styleName);
                    }
                } catch (error) {
                    localStorage.removeItem("theme");
                }
            })();
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css")
        link(rel="shortcut icon" href="/media/images/isotype.svg" type="image/svg")

        script(src="/js/index.js" defer) 
    body.disable-scroll
        #app
